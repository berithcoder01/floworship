generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  googleId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ministryMembers MinistryMember[]
  refreshTokens   RefreshToken[]
  sessions        Session[]
  sentInvites     Invite[]  @relation("invitedBy")
  passwordResets  PasswordResetToken[]
  createdSongs    Song[]
  serviceAssignments ServiceAssignment[]
  sessionLogs     SessionExecutionLog[]
  musicians       Musician[]
  whatsappLogs    WhatsAppMessageLog[]
  createdSchedules ServiceSchedule[]
}

model Ministry {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   MinistryMember[]
  invites   Invite[]
  songs     Song[]
  schedules ServiceSchedule[]
  musicians Musician[]
  whatsappLogs WhatsAppMessageLog[]
  cycles    MonthlyScheduleCycle[]
}

model MinistryMember {
  id         String   @id @default(cuid())
  userId     String
  ministryId String
  role       String   @default("musician")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@unique([userId, ministryId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  userAgent String?
  ip        String?
  lastActiveAt DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invite {
  id         String   @id @default(cuid())
  token      String   @unique
  email      String
  ministryId String
  role       String   @default("musician")
  expiresAt  DateTime
  usedAt     DateTime?
  usedByUserId String?
  invitedById  String
  createdAt  DateTime @default(now())

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  invitedBy User @relation("invitedBy", fields: [invitedById], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Song {
  id        String   @id @default(cuid())
  title     String
  artist    String?
  defaultKey String?
  tags      String   @default("[]")
  status    String   @default("rascunho")
  notes     String?
  ministryId String
  createdById String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ministry     Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdBy    User     @relation(fields: [createdById], references: [id])
  cueSheet     SongCueSheet?
  repertoireItems ServiceRepertoireItem[]
}

model SongCueSheet {
  id                 String   @id @default(cuid())
  songId             String   @unique
  referenceTrackUrl  String?
  totalDurationSeconds Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  song   Song      @relation(fields: [songId], references: [id], onDelete: Cascade)
  blocks CueBlock[]
}

model CueBlock {
  id          String   @id @default(cuid())
  cueSheetId  String
  label       String
  startTime   Float
  endTime     Float
  duration    Float
  chordproContent String?
  order       Int

  cueSheet SongCueSheet @relation(fields: [cueSheetId], references: [id], onDelete: Cascade)
  sessionLogs SessionExecutionLog[]
}

model ServiceSchedule {
  id          String   @id @default(cuid())
  ministryId  String
  date        DateTime
  createdById String
  createdAt   DateTime @default(now())

  ministry     Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdBy    User     @relation(fields: [createdById], references: [id])
  assignments  ServiceAssignment[]
  repertoire   ServiceRepertoireItem[]
}

model ServiceAssignment {
  id          String   @id @default(cuid())
  scheduleId  String
  userId      String
  role        String
  musicianId  String?
  status      String   @default("confirmado")
  substitutionOf String?
  confirmed   Boolean  @default(false)
  confirmedAt DateTime?

  schedule ServiceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id])
}

model ServiceRepertoireItem {
  id          String   @id @default(cuid())
  scheduleId  String
  songId      String
  order       Int
  keyOverride String?

  schedule ServiceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  song     Song            @relation(fields: [songId], references: [id])
}

model SessionExecutionLog {
  id              String   @id @default(cuid())
  sessionId       String
  blockId         String
  triggeredAt     DateTime @default(now())
  wasOverride     Boolean  @default(false)
  triggeredByUserId String
  durationSeconds Float?

  block        CueBlock   @relation(fields: [blockId], references: [id])
  triggeredBy  User       @relation(fields: [triggeredByUserId], references: [id])
}

model Musician {
  id          String   @id @default(cuid())
  userId      String
  instrument  String
  ministryId  String
  worshipRoles String  @default("[]")
  whatsappPhone String?
  whatsappOptIn Boolean @default(false)
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
}

model WhatsAppMessageLog {
  id              String   @id @default(cuid())
  ministryId      String
  musicianId      String?
  templateName    String
  context         String   @default("{}")
  messageId       String?
  status          String   @default("enviado")
  responsePayload String?
  sentAt          DateTime @default(now())

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  sentBy   User     @relation(fields: [sentById], references: [id])
  sentById String
}

model MonthlyScheduleCycle {
  id                String   @id @default(cuid())
  ministryId        String
  month             Int
  year              Int
  status            String   @default("coletando_disponibilidade")
  availabilityDeadline DateTime

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
}

model MinistryConfig {
  ministryId               String   @id
  defaultFormation         String   @default("[]")
  availabilityDeadlineDays Int      @default(5)
  substitutionWindowHours  Int      @default(4)
  cycleTriggerDay          Int      @default(20)
}